{
  "name": "@salesforce/templates",
  "version": "67.0.0",
  "description": "Salesforce JS library for templates",
  "bugs": "https://github.com/forcedotcom/salesforcedx-templates/issues",
  "main": "lib/index.js",
  "author": "Salesforce",
  "homepage": "https://github.com/forcedotcom/salesforcedx-templates",
  "license": "BSD-3-Clause",
  "files": [
    "/lib"
  ],
  "dependencies": {
    "@salesforce/kit": "^3.2.6",
    "@salesforce/vscode-i18n": "^66.7.0",
    "ejs": "^5.0.2",
    "got": "^11.8.6",
    "hpagent": "^1.2.0",
    "mime-types": "^3.0.2",
    "proxy-from-env": "^2.1.0",
    "tar": "^7.5.13"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@salesforce/dev-config": "^4.3.3",
    "@salesforce/prettier-config": "^0.0.4",
    "@salesforce/ui-bundle-template-app-react-template-b2e": "^1.131.0",
    "@salesforce/ui-bundle-template-app-react-template-b2x": "^1.131.0",
    "@salesforce/ui-bundle-template-base-react-app": "^1.131.0",
    "@salesforce/ui-bundle-template-base-web-app": "^1.131.0",
    "@types/ejs": "^3.1.5",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22.19.17",
    "@types/proxy-from-env": "^1.0.4",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-salesforce": "^2.2.1",
    "eslint-config-salesforce-license": "^1.0.2",
    "eslint-config-salesforce-typescript": "^4.0.1",
    "eslint-plugin-header": "^3.0.0",
    "eslint-plugin-jsdoc": "^46.10.1",
    "eslint-plugin-sf-plugin": "^1.20.33",
    "husky": "^9.1.7",
    "knip": "^6.6.2",
    "prettier": "^3.8.3",
    "pretty-quick": "^4.2.2",
    "shx": "^0.4.0",
    "ts-morph": "^24.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5",
    "wireit": "^0.14.12"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "wireit",
    "build:copy-templates": "wireit",
    "build:templates": "wireit",
    "clean:lib": "shx rm -rf lib coverage .wireit .eslintcache",
    "compile": "wireit",
    "check:knip": "wireit",
    "lint": "wireit",
    "lint:fix": "eslint -c .eslintrc.json --ext .ts ./src ./test --fix",
    "precommit": "wireit",
    "prepare": "husky",
    "prepush": "wireit",
    "scanTs": "wireit",
    "test": "wireit",
    "test:hook": "vitest run",
    "test:watch": "vitest",
    "verify-for-bundling": "wireit"
  },
  "publishConfig": {
    "access": "public"
  },
  "wireit": {
    "compile": {
      "command": "tsc -b",
      "files": [
        "src/**/*.ts",
        "!src/templates/**",
        "tsconfig.json",
        "tsconfig.settings.json"
      ],
      "output": [
        "lib/**",
        ".tsbuildinfo"
      ],
      "clean": "if-file-deleted"
    },
    "lint": {
      "command": "eslint -c .eslintrc.json --ext .ts ./src ./test --cache --cache-location .eslintcache",
      "files": [
        "src/**/*.ts",
        "test/**/*.ts",
        ".eslintrc.json",
        "tsconfig.eslint.json",
        "tsconfig.json",
        "tsconfig.settings.json"
      ],
      "output": []
    },
    "scanTs": {
      "command": "node scripts/scanTs.js",
      "dependencies": [
        "compile"
      ],
      "files": [
        "scripts/scanTs.js"
      ],
      "output": []
    },
    "check:knip": {
      "command": "knip --include exports,types,nsExports,nsTypes --no-config-hints",
      "dependencies": [
        "compile"
      ],
      "files": [
        "knip.json",
        "test/**/*.ts",
        "scripts/*.js",
        "package.json"
      ],
      "output": []
    },
    "build:copy-templates": {
      "command": "node scripts/copy-templates.js",
      "dependencies": [
        "compile"
      ],
      "files": [
        "scripts/copy-templates.js",
        "package.json"
      ],
      "output": [
        "src/templates/uiBundles/**",
        "src/templates/project/reactinternalapp/**",
        "src/templates/project/reactexternalapp/**"
      ],
      "clean": false
    },
    "build:templates": {
      "command": "node scripts/build-templates.js",
      "dependencies": [
        "build:copy-templates"
      ],
      "files": [
        "src/templates/**",
        "scripts/build-templates.js"
      ],
      "output": [
        "lib/templates/**"
      ]
    },
    "build": {
      "dependencies": [
        "build:templates"
      ]
    },
    "test": {
      "command": "vitest run --coverage",
      "dependencies": [
        "build"
      ],
      "files": [
        "vitest.config.ts"
      ],
      "output": [
        "coverage/**"
      ]
    },
    "verify-for-bundling": {
      "command": "node scripts/verify-for-bundling.js",
      "dependencies": [
        "build"
      ],
      "files": [
        "scripts/verify-for-bundling.js"
      ],
      "output": []
    },
    "precommit": {
      "dependencies": [
        "compile",
        "lint",
        "check:knip",
        "scanTs"
      ]
    },
    "prepush": {
      "dependencies": [
        "precommit",
        "build",
        "test",
        "verify-for-bundling"
      ]
    }
  }
}
