{
  "name": "@salesforce/templates",
  "version": "67.0.0",
  "description": "Salesforce JS library for templates",
  "bugs": "https://github.com/forcedotcom/salesforcedx-templates/issues",
  "main": "lib/index.js",
  "author": "Salesforce",
  "homepage": "https://github.com/forcedotcom/salesforcedx-templates",
  "license": "BSD-3-Clause",
  "files": [
    "/lib",
    "/messages"
  ],
  "dependencies": {
    "@salesforce/kit": "^3.2.6",
    "@salesforce/vscode-i18n": "^66.7.0",
    "ejs": "^5.0.2",
    "got": "^11.8.6",
    "hpagent": "^1.2.0",
    "mime-types": "^3.0.2",
    "proxy-from-env": "^1.1.0",
    "tar": "^7.5.13"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@salesforce/dev-config": "^4.3.3",
    "@salesforce/prettier-config": "^0.0.4",
    "@salesforce/ui-bundle-template-app-react-template-b2e": "^1.123.0",
    "@salesforce/ui-bundle-template-app-react-template-b2x": "^1.123.0",
    "@salesforce/ui-bundle-template-base-react-app": "^1.123.0",
    "@salesforce/ui-bundle-template-base-web-app": "^1.123.0",
    "@types/ejs": "^3.1.5",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22.19.17",
    "@types/proxy-from-env": "^1.0.4",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "^4.1.5",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-salesforce": "^2.2.1",
    "eslint-config-salesforce-license": "^1.0.2",
    "eslint-config-salesforce-typescript": "^4.0.1",
    "eslint-plugin-header": "^3.0.0",
    "eslint-plugin-jsdoc": "^46.10.1",
    "eslint-plugin-sf-plugin": "^1.20.33",
    "knip": "^6.6.2",
    "prettier": "^3.8.3",
    "pretty-quick": "^4.2.2",
    "shx": "^0.4.0",
    "ts-morph": "^24.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "yarn run clean:lib && yarn compile && yarn build:copy-templates && yarn build:templates",
    "build:templates": "node scripts/build-templates",
    "build:copy-templates": "node scripts/copy-templates",
    "clean:lib": "shx rm -rf lib && shx rm -rf coverage",
    "commit": "git-cz",
    "compile": "tsc -b",
    "lint": "eslint -c .eslintrc.json --ext .ts ./src ./test",
    "lint:fix": "eslint -c .eslintrc.json --ext .ts ./src ./test --fix",
    "test": "vitest run --coverage",
    "test:hook": "vitest run",
    "test:watch": "vitest",
    "check:knip": "knip --no-exit-code"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
