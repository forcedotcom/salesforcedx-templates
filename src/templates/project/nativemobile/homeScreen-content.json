{
  "type": "experience__camaScreen",
  "title": "Home Screen",
  "contentBody": {
    "view": {
      "definition": "<%= appName %>/HomeScreen",
      "properties": {
        "pullToRefresh": true
      },
      "regions": {
        "components": {
          "components": [
            {
              "definition": "ui/container",
              "properties": {
                "padding": "$spacing.spacing4",
                "backgroundColor": "$colors.surface2"
              },
              "regions": {
                "components": {
                  "components": [
                    {
                      "definition": "ui/card",
                      "properties": {},
                      "regions": {
                        "components": {
                          "components": [
                            {
                              "definition": "ui/column",
                              "properties": {
                                "width": "fill",
                                "height": "fill",
                                "alignment": "center",
                                "gap": "$spacing.spacing4",
                                "padding": "$spacing.spacing6"
                              },
                              "regions": {
                                "components": {
                                  "components": [
                                    {
                                      "definition": "ui/text",
                                      "properties": {
                                        "text": "Welcome",
                                        "style": "titlesFontScale4Semibold",
                                        "color": "$colors.onSurface1"
                                      },
                                      "regions": {}
                                    },
                                    {
                                      "definition": "ui/text",
                                      "properties": {
                                        "text": "Your native mobile app is ready. Start building!",
                                        "color": "$colors.onSurface2",
                                        "style": "bodyFontScale2Regular"
                                      },
                                      "regions": {}
                                    }
                                  ]
                                }
                              }
                            }
                          ]
                        }
                      }
                    }
                  ]
                }
              }
            }
          ]
        }
      }
    },
    "target": "native__<%= appName %>Home",
    "apiName": "uem_<%= appName %>Home"
  }
}
